{
  "name": "ai-job-app",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.23.1"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "svelte-kit sync",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "node scripts/check.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,svelte,css,html}\" \"scripts/**/*.mjs\" \"*.{js,cjs,ts,json,md}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,css,html}\" \"scripts/**/*.mjs\" \"*.{js,cjs,ts,json,md}\" \"docs/**/*.md\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:set": "node scripts/set-version.mjs",
    "release:verify": "node scripts/verify-release-suite.mjs",
    "tauri": "node scripts/tauri.mjs",
    "tauri:dev": "node scripts/tauri.mjs dev",
    "sidecar:build": "powershell -ExecutionPolicy Bypass -File scripts/build-sidecar.ps1",
    "tauri:bundle": "node scripts/bundle.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.2.6",
    "lucide-svelte": "^0.468.0",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.37.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@tauri-apps/cli": "^2.8.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/svelte": "^5.2.8",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.38.0",
    "svelte-check": "^4.3.1",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "cookie": "0.7.2"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-svelte"
    ],
    "printWidth": 100,
    "proseWrap": "preserve",
    "semi": true,
    "singleQuote": true,
    "trailingComma": "none"
  }
}
